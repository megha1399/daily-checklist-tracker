# Copy to .env — never commit real values.
# Required: PostgreSQL (e.g. Neon). The API does not run without DATABASE_URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Use a long random string in production (signs JWTs).
JWT_SECRET=change-me-to-a-long-random-secret

# Production (e.g. Oracle VM): serve Angular from the same Node process after `ng build`.
# Path is relative to the repo root if not absolute (folder that contains index.html).
# STATIC_DIR=dist/habit-tracker/browser

# Listen address (0.0.0.0 = accept traffic on the VM’s public interface).
# HOST=0.0.0.0

FRONTEND_URL=https://daily-checklist-tracker.onrender.com
# FRONTEND_URL=http://localhost:4200
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=test@gmail.com
SMTP_PASS=testpassword
EMAIL_FROM=Daily Checklist Tracker <test@gmail.com>
# Optional: hours until verify link expires (default 48)
VERIFY_EXPIRY_HOURS=48
